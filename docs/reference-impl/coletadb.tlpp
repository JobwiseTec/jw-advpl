#INCLUDE "TOTVS.CH"
#INCLUDE "FILEIO.CH"
#include "tlpp-core.th"
#include "tlpp-rest.th"

/*
+--------------------------------------------------------------------------+
| COLETADB.tlpp                                                            |
| Coletor de dicionario Protheus: extrai SX, MPMENU, Schedules, Jobs e    |
| record counts pra arquivos CSV locais. Saida 100% offline (sem upload). |
|                                                                          |
| Dois pontos de entrada:                                                  |
|   1) UI: U_COLETADB -- dialog interativo do SmartClient.                |
|   2) API REST: WSRESTFUL COLETADBAPI (PATH /coletadb/run e /file).     |
|      Cliente externo dispara coleta via POST e baixa CSVs em chunks.   |
|                                                                          |
| Versao: 1.2.0                                                            |
| Linguagem: ADVPL (User Function + WSRESTFUL classic)                     |
| Compatibilidade: Protheus 12.1.2410+                                     |
|                                                                          |
| Encoding ANSI (Windows-1252), CRLF. Strings sem acentos pra portabilidade|
+--------------------------------------------------------------------------+
*/

